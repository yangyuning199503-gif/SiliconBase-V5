# SiliconBase V5 环境配置示例
# 复制此文件为 .env 并填写实际配置值

# ═══════════════════════════════════════════════════════════════
# 基础服务配置
# ═══════════════════════════════════════════════════════════════

# HTTP API 端口
API_PORT=8600

# WebSocket 端口
WEBSOCKET_PORT=8601

# 前端端口
FRONTEND_PORT=5173

# ═══════════════════════════════════════════════════════════════
# PostgreSQL 数据库配置
# ═══════════════════════════════════════════════════════════════

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=siliconbase
POSTGRES_USER=postgres
# 【安全要求】生产环境必须设置强密码（>=12字符）
POSTGRES_PASSWORD=your_secure_password_here

# 连接池配置
POSTGRES_POOL_MIN=5
POSTGRES_POOL_MAX=30

# ═══════════════════════════════════════════════════════════════
# JWT 安全配置
# ═══════════════════════════════════════════════════════════════

# 【安全要求】生产环境必须更换为随机生成的强密钥
JWT_SECRET_KEY=your-random-secret-key-here

# ═══════════════════════════════════════════════════════════════
# BTC 量化交易配置
# ═══════════════════════════════════════════════════════════════

# BTC 系统路径（btc_system_v1 安装位置）
BTC_SYSTEM_PATH=F:/btc_system_v1

# OKX API 配置（实盘交易）
# 从 OKX 官网获取: https://www.okx.com/account/my-api
# 【安全警告】实盘交易涉及真实资金，请确保了解风险
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# OKX API 配置（模拟盘）
# 推荐先使用模拟盘测试系统
OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_PASSPHRASE=

# 交易模式: demo(模拟盘) / live(实盘)
# 建议先用 demo 模式测试，确认无误后再切换到 live
BTC_TRADING_MODE=demo

# 默认交易标的（逗号分隔）
# 支持: BTC, ETH, SOL, BNB, XRP, ADA, DOGE, DOT
BTC_TRADING_SYMBOLS=BTC,ETH,SOL

# ═══════════════════════════════════════════════════════════════
# 功能开关
# ═══════════════════════════════════════════════════════════════

AUTO_ENABLE_MCP=false
AUTO_ENABLE_SUBAGENT=true
ANONYMIZED_TELEMETRY=False
