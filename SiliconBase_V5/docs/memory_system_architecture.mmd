```mermaid
%% 前后端记忆系统协同架构图

graph TB
    subgraph Frontend["前端 (React + TypeScript)"]
        UI1[MemoryPanel<br/>记忆面板]
        UI2[ChatArea<br/>对话区域]
        UI3[MemoryAwareness<br/>记忆感知提示]
        Store[MemoryStore<br/>Zustand状态管理]
        Provider[MemoryProvider<br/>WebSocket/轮询]
        API[memoryAPI.ts<br/>API封装]
    end

    subgraph Backend["后端 (FastAPI + Python)"]
        Router[MemoryRouter<br/>API路由]
        WS[WebSocketHandler<br/>实时推送]
        Trigger[MemoryTrigger<br/>自动触发器]
        Manager[MemoryManager<br/>记忆管理]
        Events[EventBus<br/>事件总线]
    end

    subgraph Storage["存储层"]
        PG[(PostgreSQL<br/>主存储)]
        Vector[(ChromaDB<br/>向量存储)]
        Redis[(Redis<br/>缓存/消息)]
    end

    %% 前端内部连接
    UI1 --> Store
    UI2 --> Store
    UI3 --> Store
    Store --> Provider
    Provider --> API
    
    %% 前端到后端
    API -->|HTTP| Router
    Provider -->|WebSocket| WS
    
    %% 后端内部连接
    Router --> Manager
    WS --> Events
    Trigger --> Manager
    Manager --> Events
    
    %% 后端到存储
    Manager --> PG
    Manager --> Vector
    Events --> Redis
    
    %% 存储到后端
    PG -->|变更通知| Events
    
    %% 后端到前端
    Events -->|推送| WS
    Router -->|响应| API
```

```mermaid
%% 记忆数据流图

sequenceDiagram
    participant User as 用户
    participant FE as 前端
    participant BE as 后端
    participant DB as PostgreSQL
    participant WS as WebSocket

    %% 创建记忆
    User->>FE: 输入消息
    FE->>BE: POST /api/chat
    BE->>BE: MemoryTrigger.on_user_input()
    BE->>DB: INSERT memory (L2)
    BE->>WS: 发布变更事件
    WS->>FE: 推送 memory_created
    FE->>FE: MemoryStore.addMemory()
    FE->>User: UI更新显示

    %% AI回复
    BE->>BE: AI生成回复
    BE->>BE: MemoryTrigger.on_ai_response()
    BE->>DB: INSERT memory (L2)
    BE->>WS: 发布变更事件
    WS->>FE: 推送 memory_created
    FE->>FE: 更新对话 + 记忆
    FE->>User: 显示回复和记忆引用

    %% 初始加载
    User->>FE: 打开应用
    FE->>BE: GET /api/memories
    BE->>DB: SELECT memories
    DB->>BE: 返回数据
    BE->>FE: 返回记忆列表
    FE->>FE: MemoryStore.batchUpdate()
    FE->>User: 渲染记忆面板

    %% 增量同步
    Note over FE,BE: 30秒后
    FE->>BE: GET /api/memories/delta-sync
    BE->>DB: 查询变更
    DB->>BE: 返回变更
    BE->>FE: 返回 delta (created/updated/deleted)
    FE->>FE: 合并变更
```

