# SiliconBase V5 前端环境变量示例
# 复制本文件为 .env 后按需修改，.env 不应提交到版本控制

# API 后端地址（Vite 开发代理会转发到该地址）
VITE_API_SCHEME=http
VITE_API_HOST=127.0.0.1
VITE_API_PORT=8600

# WebSocket 地址（后端统一在 8600 端口）
VITE_WS_SCHEME=ws
VITE_WS_HOST=127.0.0.1
VITE_WS_PORT=8600

# 前端开发服务器地址
VITE_FRONTEND_SCHEME=http
VITE_FRONTEND_HOST=127.0.0.1
VITE_FRONTEND_PORT=5173
